Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Log10", "[", 
            RowBox[{"\"\<mpD\>\"", 
             FractionBox[
              SuperscriptBox["\"\<c\>\"", "2"], "\"\<JpereV\>\""]}], "]"}], 
           ",", 
           RowBox[{"Log10", "@", "\"\<\[Kappa]\>\""}], ",", 
           RowBox[{"10", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               FractionBox["1", "2"], 
               RowBox[{"Log10", "@", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox["\"\<v0\>\"", "2"], "+", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"1", "-", "\"\<\[Delta]\>\""}], ")"}], 
                   SuperscriptBox[
                    RowBox[{"(", "\"\<vesc\>\"", ")"}], "2"]}]}], ")"}]}]}], 
              "-", 
              RowBox[{
               FractionBox["1", "2"], 
               RowBox[{"Log10", "[", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", "\"\<vesc\>\"", ")"}], "2"], "+", 
                 SuperscriptBox["\"\<v0\>\"", "2"]}], "]"}]}]}], ")"}]}]}], 
          "}"}], "/.", 
         RowBox[{"Flatten", "@", "truthdict"}]}], "/.", 
        RowBox[{"Private`r", "->", 
         RowBox[{"\"\<rE\>\"", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            SuperscriptBox["10", 
             RowBox[{"-", "5"}]]}], ")"}]}]}]}], "/.", "EarthRepl"}], "/.", 
      "SIConstRepl"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"plot", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ListDensityPlot", "[", 
         RowBox[{"data", ",", 
          RowBox[{"PlotLabel", "->", 
           RowBox[{
           "\"\<\!\(\*FractionBox[\(\*SubscriptBox[\(v\), \(0, \
\*SubscriptBox[\(e\), \(D\)]\)] \((\*SubscriptBox[\(\[Phi]\), \(D\)], \
\*SubscriptBox[\(\[Phi]\), \(g\)])\)\), \(\*SubscriptBox[SubscriptBox[\(v\), \
\(0\)], \(\(,\)\*SubscriptBox[\(e\), \(D\)]\)] \((0, \
\*SubscriptBox[\(\[Phi]\), \(g\)])\)\)]\) - Disk, \>\"", "<>", "parstring", 
            "<>", "\"\< \!\(\*SuperscriptBox[SubscriptBox[\(v\), \(esc\\\ \
Sun, \*SubscriptBox[\(p\), \(D\)]\)], \(2\)]\)=\>\"", "<>", "vescstring"}]}], 
          ",", 
          RowBox[{"FrameLabel", "->", 
           RowBox[{"{", 
            RowBox[{
            "\"\<\!\(\*SubscriptBox[\(Log\), \
