[\!\(\*SubscriptBox[\(Log\), \(10\)]\)]\>\"", ",", 
         "\"\<\!\(\*SuperscriptBox[\(s\), \
\(-1\)]\)\!\(\*SuperscriptBox[\(m\), \(-3\)]\)\>\""}], "}"}]}]}], 
     "]"}]}]}]}]], "Input",
