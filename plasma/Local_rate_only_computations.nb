Cell[BoxData[{"\"\<no inner shells\>\"", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Beta]resc", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"(*", 
      RowBox[{"HeavisideTheta", "[", 
       RowBox[{"1", "-", 
        RowBox[{
         FractionBox["\"\<\[Omega]edgei\>\"", "z"], 
         SqrtBox[
          FractionBox[
           RowBox[{
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}], "\[Beta]resc", " ", 
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]], 
         SuperscriptBox[
          RowBox[{"(", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{"\[Beta]resc", 
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
          RowBox[{"-", "1"}]]}]}], "]"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{"\"\<\[Omega]edgei\>\"", 
            SqrtBox[
             FractionBox[
              RowBox[{
               RowBox[{"#", "[", "\"\<mN\>\"", "]"}], "\[Beta]resc", " ", 
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]], 
            SuperscriptBox[
             RowBox[{"(", 
              SqrtBox[
               FractionBox[
                RowBox[{"8", " ", 
                 RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                RowBox[{"\[Beta]resc", 
                 RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                 SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
             RowBox[{"-", "1"}]]}], "]"}], ">", "0.003"}], ",", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"1", "-", 
           RowBox[{
            FractionBox["\"\<\[Omega]edgei\>\"", "z"], 
            SqrtBox[
             FractionBox[
              RowBox[{
               RowBox[{"#", "[", "\"\<mN\>\"", "]"}], "\[Beta]resc", " ", 
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]], 
            SuperscriptBox[
             RowBox[{"(", 
              SqrtBox[
               FractionBox[
                RowBox[{"8", " ", 
