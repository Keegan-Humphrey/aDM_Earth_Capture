Cell[CellGroupData[{

Cell[BoxData[{"\"\<w inner shells\>\"", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Beta]resc", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"#", "[", "\"\<Z\>\"", "]"}], "2"], 
            RowBox[{"(", 
             FractionBox["1", 
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", " ", "\[Pi]", ")"}], "2"], 
               SuperscriptBox["\"\<\[HBar]\>\"", "2"], "\[Beta]resc", 
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}]], " ", 
             RowBox[{"(*", 
              RowBox[{"from", " ", "jac"}], "*)"}], ")"}], 
            RowBox[{"(*", 
             RowBox[{"(", 
              FractionBox[
               RowBox[{
                RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                "\"\<\[HBar]\>\""}], "4"], " ", 
              RowBox[{"(*", 
               RowBox[{"from", " ", "jac"}], "*)"}], ")"}], "*)"}], 
            RowBox[{
             RowBox[{"GetTargetResponses", "[", "]"}], "[", "\"\<therm\>\"", 
             "]"}]}], "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Private`z", "->", "z"}], ",", 
             RowBox[{"Private`u", "->", "u"}]}], "}"}]}], "/.", 
          RowBox[{"{", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"z", "->", 
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 SqrtBox[
                  FractionBox[
                   RowBox[{"8", " ", 
                    RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                   RowBox[{
                    RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                    SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
                RowBox[{"-", "1"}]], "q"}]}], ","}], "*)"}], 
           RowBox[{"u", "->", 
            RowBox[{
             FractionBox["\[Omega]", "q"], 
             SqrtBox[
              FractionBox[
               RowBox[{
                RowBox[{"#", "[", "\"\<mN\>\"", "]"}], "\[Beta]resc", " ", 
                RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]]}]}], 
           "}"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{"\[Omega]", "->", 
           FractionBox[
            RowBox[{"\"\<\[HBar]\>\"", 
             SuperscriptBox["q", "2"]}], 
            RowBox[{"2", " ", 
             RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}]]}], "}"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"q", "->", 
          RowBox[{"z", " ", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{"\[Beta]resc", 
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]]}]}], "}"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"\"\<zD\>\"", "->", 
         RowBox[{"\"\<qF\>\"", 
          SuperscriptBox[
           RowBox[{"(", 
            SqrtBox[
             FractionBox[
              RowBox[{"8", " ", 
               RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
              RowBox[{"\[Beta]resc", 
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
               SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
           RowBox[{"-", "1"}]]}]}], "}"}]}], "&"}], "@", "FeNucCoeffs"}], "/.",
     "SIConstRepl"}], "/.", "FeTotalparams"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Quiet", "@", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Log10", "[", 
     RowBox[{"%", "/.", 
      RowBox[{"z", "->", 
       SuperscriptBox["10", "logz"]}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"logz", ",", 
      RowBox[{"-", "10"}], ",", "5"}], "}"}], ",", 
    RowBox[{"PlotStyle", "->", "Red"}], ",", 
    RowBox[{
    "PlotLabel", "->", 
     "\"\<\!\(\*FractionBox[\(d\\\ \*SubscriptBox[\(\[CapitalGamma]\), \(Nuc, \
Fe\)]\), \(d\\\ z\)]\)(z) , From RPA - Flat Probe Density (w \
\!\(\*SuperscriptBox[\(Z\), \(2\)]\))\>\""}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{
      "\"\<z =\!\(\*SqrtBox[FractionBox[\(\*SubscriptBox[\(\[Beta]\), \(Fe\)] \
\*SuperscriptBox[\(\[HBar]\), \(2\)] \*SuperscriptBox[\(q\), \(2\)]\), \(8\\\ \
\*SubscriptBox[\(m\), \(Fe\)]\)]]\) [\!\(\*SubscriptBox[\(Log\), \(10\)]\)]\>\
\"", ",", 
       "\"\<\!\(\*SuperscriptBox[\(s\), \(-1\)]\)\!\(\*SuperscriptBox[\(m\), \
\(-3\)]\)\>\""}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Quiet", "@", 
