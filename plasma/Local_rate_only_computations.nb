Cell[CellGroupData[{

Cell[BoxData[{"\"\<Nuclear w naive nuclear screening (no electrons) in u z \
variables on the static line\>\"", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          FractionBox["1", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"2", " ", "\[Pi]"}], ")"}], "2"], "\"\<\[HBar]\>\""}]], 
          FractionBox["4", 
           RowBox[{"\"\<\[HBar]\>\"", 
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}]]}], 
         RowBox[{"(*", 
          RowBox[{"from", " ", "jac"}], "*)"}], ")"}], 
        RowBox[{"(*", 
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], "\"\<\[HBar]\>\""}], 
           "4"], " ", 
          RowBox[{"(*", 
           RowBox[{"from", " ", "jac"}], "*)"}], ")"}], "*)"}], 
        RowBox[{
         RowBox[{"GetTargetResponses", "[", "]"}], "[", "\"\<therm\>\"", 
         "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Private`z", "->", "z"}], ",", 
         RowBox[{"Private`u", "->", "u"}]}], "}"}]}], 
      RowBox[{"(*", 
       RowBox[{"/.", 
        RowBox[{"{", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"z", "->", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               SqrtBox[
                FractionBox[
                 RowBox[{"8", " ", 
                  RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                  SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
              RowBox[{"-", "1"}]], "q"}]}], ","}], "*)"}], 
         RowBox[{"u", "->", 
          RowBox[{
           FractionBox["\[Omega]", "q"], 
           SqrtBox[
            FractionBox[
             RowBox[{
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}], " ", 
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]]}]}], 
         "}"}]}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{"/.", 
        RowBox[{"{", 
         RowBox[{"\[Omega]", "->", 
          FractionBox[
           RowBox[{"\"\<\[HBar]\>\"", 
            SuperscriptBox["q", "2"]}], 
           RowBox[{"2", " ", 
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}]]}], "}"}]}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{"/.", 
        RowBox[{"{", 
         RowBox[{"q", "->", 
          RowBox[{"z", " ", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]]}]}], "}"}]}], "*)"}],
       "/.", 
      RowBox[{"{", 
       RowBox[{"\"\<zD\>\"", "->", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           RowBox[{"#", "[", "\"\<nI\>\"", "]"}], 
           RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], " ", 
           FractionBox[
            SuperscriptBox["\"\<e\>\"", "2"], "\"\<\[Epsilon]0\>\""]}]], 
         SuperscriptBox[
          RowBox[{"(", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
          RowBox[{"-", "1"}]]}]}], "}"}]}], "&"}], "@", "FeNucCoeffs"}], "/.",
    "SIConstRepl"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Quiet", "@", 
  RowBox[{"DensityPlot", "[", 
   RowBox[{
    RowBox[{"Log10", "[", 
     RowBox[{"%", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"z", "->", 
         SuperscriptBox["10", "logz"]}], ",", 
        RowBox[{"u", "->", 
         SuperscriptBox["10", "logu"]}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"logu", ",", 
      RowBox[{"-", "3"}], ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"logz", ",", 
      RowBox[{"-", "3"}], ",", "5"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{
    "PlotLabel", "->", 
     "\"\<\!\(\*SubscriptBox[\(Log\), \
\(10\)]\)\!\(\*FractionBox[\(\*SuperscriptBox[\(d\), \(2\)]\\\ \
\*SubscriptBox[\(\[CapitalGamma]\), \(Nuc, Fe\)]\), \(d\\\ z\\\ du\)]\)(u,z) \
, From RPA - Flat Probe Density (no \!\(\*SuperscriptBox[\(Z\), \
\(2\)]\))\>\""}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
      "\"\<\!\(\*SubscriptBox[\(Log\), \(10\)]\)u - u=\!\(\*FractionBox[\(\
\[Omega]\), \(q\)]\)\!\(\*SqrtBox[FractionBox[\(\*SubscriptBox[\(m\), \(Fe\)] \
\*SubscriptBox[\(\[Beta]\), \(Fe\)]\), \(2\)]]\)\>\"", ",", 
       "\"\<\!\(\*SubscriptBox[\(Log\), \(10\)]\)z - \
z=\!\(\*SqrtBox[FractionBox[\(\*SubscriptBox[\(\[Beta]\), \(Fe\)] \
\*SuperscriptBox[\(\[HBar]\), \(2\)] \*SuperscriptBox[\(q\), \(2\)]\), \(8\\\ \
\*SubscriptBox[\(m\), \(Fe\)]\)]]\)\>\""}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.980505473308733*^9, 3.9805055998870215`*^9}},
 CellLabel->
  "In[127]:=",ExpressionUUID->"1f10725b-d085-4b90-a8ce-7a907690b271"],

