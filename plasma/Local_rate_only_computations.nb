 CellChangeTimes->{{3.9818085115833907`*^9, 
  3.9818085294063253`*^9}},ExpressionUUID->"447a4f08-c737-4e2f-aca7-\
5ebe9680d220"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GetTargetResponses", "[", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"%", "[", "\"\<therm\>\"", "]"}], "/.", 
  RowBox[{
   RowBox[{"s_Symbol", "/;", 
    RowBox[{
     RowBox[{"Context", "[", "s", "]"}], "===", "\"\<Private`\>\""}]}], ":>", 
   RowBox[{"Symbol", "[", 
    RowBox[{"SymbolName", "[", "s", "]"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"%%", "[", "\"\<bnd\>\"", "]"}], "/.", 
    RowBox[{
     RowBox[{"s_Symbol", "/;", 
      RowBox[{
       RowBox[{"Context", "[", "s", "]"}], "===", "\"\<Private`\>\""}]}], ":>", 
     RowBox[{"Symbol", "[", 
      RowBox[{"SymbolName", "[", "s", "]"}], "]"}]}]}], "//", "Simplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"%%%", "[", "\"\<amb\>\"", "]"}], "/.", 
    RowBox[{
     RowBox[{"s_Symbol", "/;", 
      RowBox[{
       RowBox[{"Context", "[", "s", "]"}], "===", "\"\<Private`\>\""}]}], ":>", 
     RowBox[{"Symbol", "[", 
      RowBox[{"SymbolName", "[", "s", "]"}], "]"}]}]}], "//", "Simplify"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"%", "/.", 
      RowBox[{"\"\<zD\>\"", "->", "zD"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"zD", ",", "0", ",", "2"}], "}"}]}], "]"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.981808533691902*^9, 3.981808553902097*^9}, {
  3.9818085853344045`*^9, 3.9818086207361383`*^9}, {3.981808694013364*^9, 
  3.981808737500207*^9}, {3.9818087711664543`*^9, 3.9818087758975916`*^9}, {
  3.981810217220598*^9, 3.9818102662974024`*^9}, {3.9818103042340407`*^9, 
  3.9818103052618246`*^9}},
 CellLabel->
  "In[970]:=",ExpressionUUID->"ac8f1d9f-2260-4a27-8cf1-0f83a063646b"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\<\"e\"\>", "2"], " ", 
   SuperscriptBox["\<\"zD\"\>", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"u", "-", "z"}], ")"}], "2"]}]], " ", "\[Pi]"}], "-", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"u", "+", "z"}], ")"}], "2"]}]], " ", "\[Pi]"}]}], ")"}]}], 
  RowBox[{"2", " ", "\<\"\[Epsilon]0\"\>", " ", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "4"}], " ", "u", " ", "z"}]]}], ")"}], " ", 
   SqrtBox["\[Pi]"], " ", 
   SuperscriptBox["z", "3"], " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\<\"zD\"\>", "4"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"-", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"u", "-", "z"}], ")"}], "2"]}]], " ", "\[Pi]"}], "-", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"-", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"u", "+", "z"}], ")"}], "2"]}]], " ", "\[Pi]"}]}], 
         ")"}], "2"]}], 
      RowBox[{"16", " ", "\[Pi]", " ", 
       SuperscriptBox["z", "6"]}]], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", 
        FractionBox[
         RowBox[{
          SuperscriptBox["\<\"zD\"\>", "2"], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", 
             SqrtBox["\[Pi]"], " ", 
             RowBox[{"DawsonF", "[", 
              RowBox[{"u", "-", "z"}], "]"}]}], "+", 
            RowBox[{"2", " ", 
             SqrtBox["\[Pi]"], " ", 
             RowBox[{"DawsonF", "[", 
              RowBox[{"u", "+", "z"}], "]"}]}]}], ")"}]}], 
         RowBox[{"4", " ", 
          SqrtBox["\[Pi]"], " ", 
          SuperscriptBox["z", "3"]}]]}], ")"}], "2"]}], ")"}]}]]], "Output",
 CellChangeTimes->{
  3.981808541091566*^9, {3.9818085877490253`*^9, 3.9818086211777*^9}, {
   3.981808695331773*^9, 3.9818087377890177`*^9}, 3.98180877824648*^9, {
   3.981810230651661*^9, 3.981810266695757*^9}, 3.9818103057770233`*^9},
 CellLabel->
  "Out[971]=",ExpressionUUID->"f0564bad-c54d-4184-9b66-77475dee0f52"]
}, Open  ]],

