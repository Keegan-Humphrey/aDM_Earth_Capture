Cell[CellGroupData[{

Cell[BoxData[{"\"\<Nuclear w naive nuclear screening (no electrons) in u z \
variables on the static line\>\"", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          FractionBox["1", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"2", " ", "\[Pi]"}], ")"}], "2"], "\"\<\[HBar]\>\""}]], 
          FractionBox["4", 
           RowBox[{"\"\<\[HBar]\>\"", 
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}]]}], 
         RowBox[{"(*", 
          RowBox[{"from", " ", "jac"}], "*)"}], ")"}], 
        RowBox[{"(*", 
         RowBox[{"(", 
          FractionBox[
           RowBox[{
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], "\"\<\[HBar]\>\""}], 
           "4"], " ", 
          RowBox[{"(*", 
           RowBox[{"from", " ", "jac"}], "*)"}], ")"}], "*)"}], 
        RowBox[{
         RowBox[{"GetTargetResponses", "[", "]"}], "[", "\"\<therm\>\"", 
         "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Private`z", "->", "z"}], ",", 
         RowBox[{"Private`u", "->", "u"}]}], "}"}]}], 
      RowBox[{"(*", 
       RowBox[{"/.", 
        RowBox[{"{", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"z", "->", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               SqrtBox[
                FractionBox[
                 RowBox[{"8", " ", 
                  RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                  SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
              RowBox[{"-", "1"}]], "q"}]}], ","}], "*)"}], 
         RowBox[{"u", "->", 
          RowBox[{
           FractionBox["\[Omega]", "q"], 
           SqrtBox[
            FractionBox[
             RowBox[{
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}], " ", 
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]]}]}], 
         "}"}]}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{"/.", 
        RowBox[{"{", 
         RowBox[{"\[Omega]", "->", 
          FractionBox[
           RowBox[{"\"\<\[HBar]\>\"", 
            SuperscriptBox["q", "2"]}], 
           RowBox[{"2", " ", 
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}]]}], "}"}]}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{"/.", 
        RowBox[{"{", 
         RowBox[{"q", "->", 
          RowBox[{"z", " ", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]]}]}], "}"}]}], "*)"}],
       "/.", 
      RowBox[{"{", 
       RowBox[{"\"\<zD\>\"", "->", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           RowBox[{"#", "[", "\"\<nI\>\"", "]"}], 
           RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], " ", 
           FractionBox[
            SuperscriptBox["\"\<e\>\"", "2"], "\"\<\[Epsilon]0\>\""]}]], 
         SuperscriptBox[
          RowBox[{"(", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
          RowBox[{"-", "1"}]]}]}], "}"}]}], "&"}], "@", "FeNucCoeffs"}], "/.",
    "SIConstRepl"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Quiet", "@", 
  RowBox[{"DensityPlot", "[", 
   RowBox[{
    RowBox[{"Log10", "[", 
     RowBox[{"%", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"z", "->", 
         SuperscriptBox["10", "logz"]}], ",", 
        RowBox[{"u", "->", 
         SuperscriptBox["10", "logu"]}]}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"logu", ",", 
      RowBox[{"-", "3"}], ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"logz", ",", 
      RowBox[{"-", "3"}], ",", "5"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9805043536910887`*^9, 3.9805043645713778`*^9}, {
  3.980504548777665*^9, 3.9805047106640863`*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"85a9adb9-d048-4e1d-a2e5-66446e3193e0"],

