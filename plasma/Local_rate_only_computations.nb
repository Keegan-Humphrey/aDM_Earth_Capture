          RowBox[{"from", " ", "q"}], "->", 
          RowBox[{
           RowBox[{
            RowBox[{"z", " ", "jac"}], " ", "-", " ", 
            RowBox[{"no", " ", "\[Omega]"}]}], "->", 
           RowBox[{
