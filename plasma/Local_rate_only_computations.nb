Cell[BoxData["\<\"This drops the inner shells, and shows that the low energy \
tail and peak predicted by the form factor are captured by the outer electron \
shells in the limit u->0. If the momentum range used to construct the form \
factor falls below the peak, this also tells us that the inner shells are not \
being probed by the form factor data, and our results should be trusted more.\
\"\>"], "Output",
 CellChangeTimes->{{3.9809377184551225`*^9, 3.980937736750914*^9}, 
   3.9809378669813814`*^9, 3.980938007015775*^9, 3.9809380716674967`*^9, 
   3.9809381619163938`*^9, 3.98094057692323*^9, 3.9809410685724044`*^9},
 CellLabel->
  "Out[1528]=",ExpressionUUID->"cfb3c001-4544-4772-bee4-f8640641cde8"],

Cell[BoxData["\<\"This also shows us why the electrons didn't contribute. The \
integral is dominated by u, z <<1. So we often fall below the cutoff of the \
inner electron shells for the silicates.\"\>"], "Output",
 CellChangeTimes->{{3.9809377184551225`*^9, 3.980937736750914*^9}, 
   3.9809378669813814`*^9, 3.980938007015775*^9, 3.9809380716674967`*^9, 
   3.9809381619163938`*^9, 3.98094057692323*^9, 3.9809410685882163`*^9},
 CellLabel->
  "Out[1529]=",ExpressionUUID->"59d588c5-2fc4-48f5-bfac-ff1bd9d54f33"],

