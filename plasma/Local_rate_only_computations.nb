      RowBox[{
      "PlotLabel", "->", 
       "\"\<\!\(\*FractionBox[\(d\\\ \*SubscriptBox[\(\[CapitalGamma]\), \
\(Nuc, Fe\)]\), \(d\\\ z\)]\)(z) , From RPA - Flat Probe Density (w \
\!\(\*SuperscriptBox[\(Z\), \(2\)]\))\>\""}], ",", 
