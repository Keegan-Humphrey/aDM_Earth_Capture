Cell[BoxData[
 RowBox[{
  RowBox[{"VCoul", "[", "q_", "]"}], ":=", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", "\"\<e\>\"", ")"}], "^", "2"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"q", "^", "2"}], " ", "\"\<\[Epsilon]0\>\""}], ")"}]}], ")"}], 
  RowBox[{"(*", 
   RowBox[{"no", " ", "kappa", " ", "included", " ", "here"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.979826826310569*^9, 3.979826829332631*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"a2c0ea5a-3462-407b-a781-95ab88ac893a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"\"\<Nuclear in \[Omega] z variables\>\"", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          SqrtBox[
           FractionBox[
            RowBox[{"8", " ", 
             RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
            RowBox[{
             RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
             SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], " ", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"from", " ", "q"}], "->", 
           RowBox[{"z", " ", "jac"}]}], "*)"}], 
         FractionBox["q", 
          RowBox[{"\"\<\[HBar]\>\"", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"2", "\[Pi]"}], ")"}], "2"]}]], " ", 
         SuperscriptBox[
          RowBox[{"VCoul", "[", "q", "]"}], "2"], "2", " ", "\[Pi]", "  ", 
         RowBox[{"#", "[", "\"\<nI\>\"", "]"}], 
         RowBox[{
          RowBox[{"FormFactors`Zeff", "[", 
           RowBox[{"q", ",", "#"}], "]"}], "^", "2"}]}], " ", "/.", 
        RowBox[{"{", 
         RowBox[{"\[Omega]", "->", 
          FractionBox[
           RowBox[{"\"\<\[HBar]\>\"", 
            SuperscriptBox["q", "2"]}], 
           RowBox[{"2", " ", 
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}]]}], "}"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"q", "->", 
         RowBox[{"z", " ", 
          SqrtBox[
           FractionBox[
            RowBox[{"8", " ", 
             RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
            RowBox[{
             RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
             SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]]}]}], "}"}]}], "&"}], 
     "@", "FeNucCoeffs"}], "/.", "SIConstRepl"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         SqrtBox[
          FractionBox[
           RowBox[{"8", " ", 
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
           RowBox[{
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
            SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], " ", 
        RowBox[{"(*", 
