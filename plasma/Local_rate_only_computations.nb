Cell[BoxData[
 RowBox[{"Do", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Log10", "[", 
            RowBox[{"\"\<mpD\>\"", 
             FractionBox[
              SuperscriptBox["\"\<c\>\"", "2"], "\"\<JpereV\>\""]}], "]"}], 
           ",", 
           RowBox[{"Log10", "@", "\"\<\[Kappa]\>\""}], ",", 
           RowBox[{"10", "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               FractionBox["1", "2"], 
               RowBox[{"Log10", "@", 
                RowBox[{"(", 
                 RowBox[{
                  SuperscriptBox["\"\<v0\>\"", "2"], "+", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"1", "-", "\"\<\[Delta]\>\""}], ")"}], 
                   SuperscriptBox[
                    RowBox[{"(", "\"\<vesc\>\"", ")"}], "2"]}], "+", 
                  SuperscriptBox[
                   RowBox[{"(", "43000", ")"}], "2"]}], ")"}]}]}], "-", 
              RowBox[{
               FractionBox["1", "2"], 
               RowBox[{"Log10", "[", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", "\"\<vesc\>\"", ")"}], "2"], "+", 
                 SuperscriptBox["\"\<v0\>\"", "2"]}], "]"}]}]}], ")"}]}]}], 
          "}"}], "/.", 
         RowBox[{"Flatten", "@", "testrunlotsofsun"}]}], "/.", 
        RowBox[{"Private`r", "->", 
