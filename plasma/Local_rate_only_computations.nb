 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         SqrtBox[
          FractionBox[
           RowBox[{"8", " ", 
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
           RowBox[{
            RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
            SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], " ", 
        RowBox[{"(*", 
