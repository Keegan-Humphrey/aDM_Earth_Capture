        FractionBox["q", 
         RowBox[{"\"\<\[HBar]\>\"", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"2", "\[Pi]"}], ")"}], "2"]}]], " ", 
        RowBox[{"(", 
         FractionBox["1", "\"\<\[HBar]\>\""], " ", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"from", " ", "E"}], "->", 
           RowBox[{"\[Omega]", " ", "in", " ", "\[Delta]", " ", "fn"}]}], 
          "*)"}], ")"}], 
        SuperscriptBox[
         RowBox[{"VCoul", "[", "q", "]"}], "2"], "2", " ", "\[Pi]", "  ", 
