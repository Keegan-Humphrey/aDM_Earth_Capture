Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Note", " ", "that", " ", "this", " ", "is", " ", "assuming", " ", "that", 
    " ", "the", " ", "electrons", " ", "are", " ", "doing", " ", "the", " ", 
    "screening", " ", "so", " ", 
    RowBox[{"there", "'"}], "s", " ", "no", " ", "Z", " ", "enhancement", " ",
     "int", " ", "he", " ", "debye", " ", "momentum"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Beta]resc", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             SuperscriptBox[
              RowBox[{"#", "[", "\"\<Z\>\"", "]"}], "2"], 
             RowBox[{"(", 
              FractionBox["1", 
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", " ", "\[Pi]", ")"}], "2"], 
                SuperscriptBox["\"\<\[HBar]\>\"", "2"], "\[Beta]resc", 
                RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}]], " ", 
              RowBox[{"(*", 
               RowBox[{"from", " ", "jac"}], "*)"}], ")"}], 
             RowBox[{"(*", 
              RowBox[{"(", 
               FractionBox[
                RowBox[{
                 RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                 "\"\<\[HBar]\>\""}], "4"], " ", 
               RowBox[{"(*", 
                RowBox[{"from", " ", "jac"}], "*)"}], ")"}], "*)"}], 
             RowBox[{
              RowBox[{"GetTargetResponses", "[", "]"}], "[", "\"\<therm\>\"", 
              "]"}]}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Private`z", "->", "z"}], ",", 
              RowBox[{"Private`u", "->", "u"}]}], "}"}]}], "/.", 
           RowBox[{"{", 
            RowBox[{"(*", 
             RowBox[{
              RowBox[{"z", "->", 
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                  SqrtBox[
                   FractionBox[
                    RowBox[{"8", " ", 
                    RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                    RowBox[{
                    RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                    SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
                 RowBox[{"-", "1"}]], "q"}]}], ","}], "*)"}], 
            RowBox[{"u", "->", 
             RowBox[{
              FractionBox["\[Omega]", "q"], 
              SqrtBox[
               FractionBox[
                RowBox[{
                 RowBox[{"#", "[", "\"\<mN\>\"", "]"}], "\[Beta]resc", " ", 
                 RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]]}]}], 
            "}"}]}], "/.", 
          RowBox[{"{", 
           RowBox[{"\[Omega]", "->", 
            FractionBox[
             RowBox[{"\"\<\[HBar]\>\"", 
              SuperscriptBox["q", "2"]}], 
             RowBox[{"2", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}]]}], "}"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{"q", "->", 
           RowBox[{"z", " ", 
            SqrtBox[
             FractionBox[
              RowBox[{"8", " ", 
               RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
              RowBox[{"\[Beta]resc", 
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
               SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]]}]}], "}"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"\"\<zD\>\"", "->", 
          RowBox[{
           SqrtBox[
            RowBox[{"2", " ", 
             RowBox[{"#", "[", "\"\<nI\>\"", "]"}], "\[Beta]resc", 
             RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], " ", 
             FractionBox[
              SuperscriptBox["\"\<e\>\"", "2"], "\"\<\[Epsilon]0\>\""]}]], 
           SuperscriptBox[
            RowBox[{"(", 
             SqrtBox[
              FractionBox[
               RowBox[{"8", " ", 
                RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
               RowBox[{"\[Beta]resc", 
                RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
            RowBox[{"-", "1"}]]}]}], "}"}]}], "&"}], "@", "FeNucCoeffs"}], "/.",
      "SIConstRepl"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Quiet", "@", 
