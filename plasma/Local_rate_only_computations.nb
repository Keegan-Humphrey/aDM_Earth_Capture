Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\<\"e\"\>", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"u", "-", "z"}], ")"}], "2"]}]], " ", "\[Pi]"}], "-", 
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"u", "+", "z"}], ")"}], "2"]}]], " ", "\[Pi]"}]}], 
        ")"}], " ", 
       SuperscriptBox["zD", "2"]}], 
      RowBox[{"2", " ", "\<\"\[Epsilon]0\"\>", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "4"}], " ", "u", " ", "z"}]]}], ")"}], " ", 
       SqrtBox["\[Pi]"], " ", 
       SuperscriptBox["z", "3"]}]], "+", 
     InterpretationBox[
      SuperscriptBox[
       RowBox[{"O", "[", "zD", "]"}], "3"],
      SeriesData[$CellContext`zD, 0, {}, 2, 3, 1],
      Editable->False]}],
    SeriesData[$CellContext`zD, 0, {
     Rational[1, 2] "e"^2 
      "\[Epsilon]0"^(-1) (1 - E^((-4) $CellContext`u $CellContext`z))^(-1) 
      Pi^Rational[-1, 2] (E^(-($CellContext`u - $CellContext`z)^2) Pi - 
       E^(-($CellContext`u + $CellContext`z)^2) Pi) $CellContext`z^(-3)}, 2, 
     3, 1],
    Editable->False], ",", 
   InterpretationBox[
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox["\<\"e\"\>", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"-", 
              SuperscriptBox["\<\"zescj\"\>", "2"]}]], "+", 
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"-", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"u", "-", "z"}], ")"}], "2"]}]]}], ")"}], " ", 
          "\[Pi]", " ", 
          RowBox[{"HeavisideTheta", "[", 
           RowBox[{"\<\"zescj\"\>", "-", 
            RowBox[{"Abs", "[", 
             RowBox[{"u", "-", "z"}], "]"}]}], "]"}]}], "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"-", 
              SuperscriptBox["\<\"zescj\"\>", "2"]}]], "+", 
            SuperscriptBox["\[ExponentialE]", 
             RowBox[{"-", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"u", "+", "z"}], ")"}], "2"]}]]}], ")"}], " ", 
          "\[Pi]", " ", 
          RowBox[{"HeavisideTheta", "[", 
           RowBox[{"\<\"zescj\"\>", "-", 
            RowBox[{"Abs", "[", 
             RowBox[{"u", "+", "z"}], "]"}]}], "]"}]}]}], ")"}], " ", 
       SuperscriptBox["zD", "2"]}], 
      RowBox[{"2", " ", "\<\"\[Epsilon]0\"\>", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
