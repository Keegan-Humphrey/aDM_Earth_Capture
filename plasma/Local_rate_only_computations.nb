Cell[CellGroupData[{

Cell[BoxData[{"\"\<Nuclear w naive nuclear screening (no electrons) in \
\[Omega] z variables on the static line\>\"", "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             FractionBox["1", 
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"2", " ", "\[Pi]"}], ")"}], "2"], 
               "\"\<\[HBar]\>\""}]], " ", 
             SuperscriptBox[
              RowBox[{"(", 
               SqrtBox[
                FractionBox[
                 RowBox[{"8", " ", 
                  RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                  SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
              RowBox[{"-", "1"}]]}], 
            RowBox[{"(*", 
             RowBox[{"from", " ", "jac"}], "*)"}], ")"}], 
           RowBox[{"(*", 
            RowBox[{"(", 
             FractionBox[
              RowBox[{
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
               "\"\<\[HBar]\>\""}], "4"], " ", 
             RowBox[{"(*", 
              RowBox[{"from", " ", "jac"}], "*)"}], ")"}], "*)"}], 
           RowBox[{
            RowBox[{"GetTargetResponses", "[", "]"}], "[", "\"\<therm\>\"", 
            "]"}]}], "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Private`z", "->", "z"}], ",", 
            RowBox[{"Private`u", "->", "u"}]}], "}"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"z", "->", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                SqrtBox[
                 FractionBox[
                  RowBox[{"8", " ", 
                   RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
                  RowBox[{
                   RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
                   SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
               RowBox[{"-", "1"}]], "q"}]}], ","}], "*)"}], 
          RowBox[{"u", "->", 
           RowBox[{
            FractionBox["\[Omega]", "q"], 
            SqrtBox[
             FractionBox[
              RowBox[{
               RowBox[{"#", "[", "\"\<mN\>\"", "]"}], " ", 
               RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}]}], "2"]]}]}], 
          "}"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{"\[Omega]", "->", 
          FractionBox[
           RowBox[{"\"\<\[HBar]\>\"", 
            SuperscriptBox["q", "2"]}], 
           RowBox[{"2", " ", 
            RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}]]}], "}"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{"q", "->", 
         RowBox[{"z", " ", 
          SqrtBox[
           FractionBox[
            RowBox[{"8", " ", 
             RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
            RowBox[{
             RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
             SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]]}]}], "}"}]}], "/.", 
      RowBox[{"{", 
       RowBox[{"\"\<zD\>\"", "->", 
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           RowBox[{"#", "[", "\"\<nI\>\"", "]"}], 
           RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], " ", 
           FractionBox[
            SuperscriptBox["\"\<e\>\"", "2"], "\"\<\[Epsilon]0\>\""]}]], 
         SuperscriptBox[
          RowBox[{"(", 
           SqrtBox[
            FractionBox[
             RowBox[{"8", " ", 
              RowBox[{"#", "[", "\"\<mN\>\"", "]"}]}], 
             RowBox[{
              RowBox[{"#", "[", "\"\<\[Beta]\>\"", "]"}], 
              SuperscriptBox["\"\<\[HBar]\>\"", "2"]}]]], ")"}], 
          RowBox[{"-", "1"}]]}]}], "}"}]}], "&"}], "@", "FeNucCoeffs"}], "/.",
    "SIConstRepl"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Quiet", "@", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Log10", "[", 
     RowBox[{"%", "/.", 
      RowBox[{"z", "->", 
       SuperscriptBox["10", "logz"]}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"logz", ",", 
      RowBox[{"-", "10"}], ",", "5"}], "}"}], ",", 
    RowBox[{"PlotStyle", "->", "Red"}], ",", 
    RowBox[{
    "PlotLabel", "->", 
     "\"\<\!\(\*FractionBox[\(d\\\ \*SubscriptBox[\(\[CapitalGamma]\), \(Nuc, \
Fe\)]\), \(d\\\ z\)]\)(z) , From FFs - Flat Probe Density\>\""}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{
      "\"\<z =\!\(\*SqrtBox[FractionBox[\(\*SubscriptBox[\(\[Beta]\), \(Fe\)] \
\*SuperscriptBox[\(\[HBar]\), \(2\)] \*SuperscriptBox[\(q\), \(2\)]\), \(8\\\ \
\*SubscriptBox[\(m\), \(Fe\)]\)]]\) [ ]\>\"", ",", 
       "\"\<\!\(\*SuperscriptBox[\(s\), \(-1\)]\)\!\(\*SuperscriptBox[\(m\), \
\(-3\)]\)\>\""}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9802548011414633`*^9, 3.9802548489840727`*^9}, {
  3.980255052969119*^9, 3.9802550799994793`*^9}, {3.9802551207454863`*^9, 
  3.980255344471963*^9}, {3.9802557853105574`*^9, 3.9802557908688707`*^9}, {
  3.9802562292944455`*^9, 3.9802562301409564`*^9}, {3.9802563951524076`*^9, 
  3.9802564446684656`*^9}, {3.9802564758163385`*^9, 3.9802564768485193`*^9}, {
  3.9803729283782897`*^9, 3.980372935585867*^9}, {3.980373738643985*^9, 
  3.9803737603246512`*^9}, {3.980373790752134*^9, 3.9803738298441954`*^9}, {
  3.9805043729938507`*^9, 3.9805043925659027`*^9}, {3.9805044226880555`*^9, 
  3.980504479615363*^9}, {3.9805045103410892`*^9, 3.980504532447029*^9}, {
  3.980505043977661*^9, 3.9805050443244123`*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"6bba102e-1525-4a55-941b-44d9329629c0"],

