        RowBox[{"Differences", "[", "xa", "]"}]}], ";", 
       RowBox[{"rh", "=", 
        RowBox[{"1", "/", "h"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"del", "=", 
        RowBox[{
