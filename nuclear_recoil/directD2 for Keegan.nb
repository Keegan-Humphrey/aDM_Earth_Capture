             RowBox[{"Most", "[", "rh", "]"}]}], ",", 
            RowBox[{
             RowBox[{"Band", "[", 
              RowBox[{"{", 
               RowBox[{"1", ",", "2"}], "}"}], "]"}], "->", 
             RowBox[{"-", 
              RowBox[{"ListCorrelate", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"1", ",", "1"}], "}"}], ",", "rh"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"Band", "[", 
              RowBox[{"{", 
               RowBox[{"1", ",", "3"}], "}"}], "]"}], "->", 
             RowBox[{"Rest", "[", "rh", "]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
