          RowBox[{"Differences", "[", "del", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dc", "=", 
        RowBox[{"ya", "-", 
         RowBox[{"6", " ", 
          RowBox[{"(", 
