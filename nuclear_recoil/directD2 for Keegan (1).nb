Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"angularintminushalo", "[", "v_", "]"}], "=", 
   RowBox[{
    RowBox[{"angularintminus", "[", 
     RowBox[{"v", ",", "vEavg", ",", "v0", ",", 
      RowBox[{"Nesc", "[", "v0", "]"}]}], "]"}], "//", "Simplify"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"angularintplushalo", "[", "v_", "]"}], "=", 
   RowBox[{
    RowBox[{"angularintplus", "[", 
     RowBox[{"v", ",", "vEavg", ",", "v0", ",", 
      RowBox[{"Nesc", "[", "v0", "]"}]}], "]"}], "//", "Simplify"}]}], " ", 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"vpmhalo", "[", 
     RowBox[{"x_", ",", "mdm_", ",", "ER_", ",", "labelT_"}], "]"}], "=", " ", 
    RowBox[{"vpm", "[", 
     RowBox[{"x", ",", "mdm", ",", "ER", ",", "labelT", ",", " ", "vEavg"}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FE1Dhalo", "[", "v_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"HeavisideTheta", "[", 
        RowBox[{"ves", "+", "ve", "-", "v"}], "]"}], 
       SuperscriptBox["v", "2"], 
       RowBox[{"angularintminushalo", "[", "v", "]"}]}], " ", 
