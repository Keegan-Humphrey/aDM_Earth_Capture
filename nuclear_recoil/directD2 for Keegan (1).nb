Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "relevant", " ", "integrals", " ", "over", " ", "distribution", " ", 
     "are", " ", 
     RowBox[{"f", "/", "v"}], " ", "and", " ", "vf"}], ",", " ", 
    "precompute"}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Timing", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Eta]0", "[", 
        RowBox[{"ER_", ",", "labelT_", ",", "mdm_"}], "]"}], " ", "=", " ", 
       RowBox[{"Assuming", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ER", ">=", "0"}], " ", "&&", " ", 
          RowBox[{"mdm", ">=", " ", "0"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"mT", "[", "labelT", "]"}], ">=", "0"}]}], ",", " ", 
         RowBox[{"Integrate", "[", " ", 
          RowBox[{
           FractionBox[
            RowBox[{"FE1Dhalo", "[", "v", "]"}], "v"], ",", 
           RowBox[{"{", 
            RowBox[{"v", ",", 
             RowBox[{"vmin", "[", 
              RowBox[{"ER", ",", 
               RowBox[{"mT", "[", "labelT", "]"}], ",", "mdm"}], "]"}], ",", 
             "1"}], "}"}]}], "]"}]}], "]"}]}], ";", "\n", 
      RowBox[{
       RowBox[{"\[Eta]1", "[", 
        RowBox[{"ER_", ",", "labelT_", ",", "mdm_"}], "]"}], " ", "=", " ", 
       RowBox[{"Assuming", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ER", ">=", "0"}], " ", "&&", " ", 
          RowBox[{"mdm", ">=", " ", "0"}], " ", "&&", " ", 
          RowBox[{
           RowBox[{"mT", "[", "labelT", "]"}], ">=", "0"}]}], ",", " ", 
         RowBox[{"Integrate", "[", 
          RowBox[{
           RowBox[{"v", " ", 
            RowBox[{"FE1Dhalo", "[", "v", "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"v", ",", 
             RowBox[{"vmin", "[", 
              RowBox[{"ER", ",", 
               RowBox[{"mT", "[", "labelT", "]"}], ",", "mdm"}], "]"}], ",", 
             "1"}], "}"}]}], "]"}]}], "]"}]}], ";"}], "]"}], "\n", "\n", 
    RowBox[{"SaveIt", "[", 
     RowBox[{"\"\<VelocityIntegral0\>\"", 
      ",", "\"\<\[Eta]0[ER,labelT,mdm]\>\""}], "]"}], "\n", 
    RowBox[{"SaveIt", "[", 
     RowBox[{"\"\<VelocityIntegral1\>\"", 
      ",", "\"\<\[Eta]1[ER,labelT,mdm]\>\""}], "]"}]}], "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Eta]0", "[", 
      RowBox[{"ER_", ",", "labelT_", ",", "mdm_"}], "]"}], " ", "=", " ", 
     RowBox[{"ReadIt", "[", "\"\<VelocityIntegral0\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Eta]1", "[", 
      RowBox[{"ER_", ",", "labelT_", ",", "mdm_"}], "]"}], " ", "=", " ", 
     RowBox[{"ReadIt", "[", "\"\<VelocityIntegral1\>\"", "]"}]}], 
    ";"}]}]}]], "Code",
