Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"for", " ", "some", " ", "reason"}], ",", " ", 
    RowBox[{
    "getting", " ", "the", " ", "integrated", " ", "rate", " ", "is", " ", 
     "way", " ", "faster", " ", "when", " ", "seperating", " ", "the", " ", 
     "two", " ", "components", " ", "of", " ", "the", " ", "velocity", " ", 
     "integral", " ", "rather", " ", "than", " ", "integrating", " ", "ER", " ",
      "over", " ", "the", " ", "precomputed", " ", "velocity", " ", 
     "integrals"}]}], "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"RTintegratedgen", "[", 
      RowBox[{"labelOp_", ",", "tar_"}], "]"}], "[", 
     RowBox[{
     "mdm_", ",", "rsq_", ",", "Qdm_", ",", "\[Kappa]_", ",", "vavg_", ",", 
      "vo_"}], "]"}], ":=", " ", 
    RowBox[{"prefactordiff", 
     FractionBox[
      SuperscriptBox["\[Kappa]", "2"], "mdm"], 
     RowBox[{"(", "\n", "\t", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"\[Zeta]T", "[", 
           RowBox[{"tar", ",", "labelT"}], "]"}], 
          RowBox[{"mT", "[", "labelT", "]"}]], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             RowBox[{"v", " ", 
              SuperscriptBox["v", "2"], " ", 
              RowBox[{"angularintminus", "[", 
               RowBox[{"v", ",", "vavg", ",", "vo", ",", 
                RowBox[{"Nesc", "[", "vo", "]"}]}], "]"}], 
              RowBox[{"(*", 
               RowBox[{"acceptancerate", "[", 
                RowBox[{"ER", "*", 
                 SuperscriptBox["10", "6"]}], "]"}], "*)"}], "\n", 
              "\t\t\t\t\t\t\t", 
              RowBox[{
               RowBox[{
                RowBox[{"d\[Sigma]TdER", "[", "labelT", "]"}], "[", "labelOp",
                 "]"}], "[", 
               RowBox[{"ER", ",", "v", ",", "mdm", ",", "rsq", ",", 
                RowBox[{"mudm", "[", "mdm", "]"}], ",", "Qdm"}], "]"}]}], ",",
              "\n", "\t\t\t\t\t\t\t", 
             RowBox[{"{", 
              RowBox[{"ER", ",", 
               RowBox[{
                RowBox[{"threshold", "[", "tar", "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"threshold", "[", "tar", "]"}], "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\n", 
             "\t\t\t\t\t\t\t", 
             RowBox[{"{", 
              RowBox[{"v", ",", 
               RowBox[{"vpm", "[", 
                
                RowBox[{"\"\<plus\>\"", ",", "mdm", ",", "ER", ",", "labelT", 
                 ",", "vavg"}], "]"}], ",", 
               RowBox[{"vesc", "+", "vavg"}]}], "}"}], " ", ",", 
             RowBox[{"AccuracyGoal", "\[Rule]", "20"}]}], "]"}], "\n", 
           "\t\t\t\t\t", "\n", "\t\t\t\t\t", "-", 
           RowBox[{"NIntegrate", "[", 
            RowBox[{
             RowBox[{"v", " ", 
              SuperscriptBox["v", "2"], 
              RowBox[{"angularintplus", "[", 
               RowBox[{"v", ",", "vavg", ",", "vo", ",", 
                RowBox[{"Nesc", "[", "vo", "]"}]}], "]"}], 
              RowBox[{"(*", 
               RowBox[{"acceptancerate", "[", 
                RowBox[{"ER", "*", 
                 SuperscriptBox["10", "6"]}], "]"}], "*)"}], "\n", 
              "\t\t\t\t\t\t\t", 
              RowBox[{
               RowBox[{
                RowBox[{"d\[Sigma]TdER", "[", "labelT", "]"}], "[", "labelOp",
                 "]"}], "[", 
               RowBox[{"ER", ",", "v", ",", "mdm", ",", "rsq", ",", 
                RowBox[{"mudm", "[", "mdm", "]"}], ",", "Qdm"}], "]"}]}], ",",
              "\n", "\t\t\t\t\t\t\t", 
             RowBox[{"{", 
              RowBox[{"ER", ",", 
               RowBox[{
                RowBox[{"threshold", "[", "tar", "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{"threshold", "[", "tar", "]"}], "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", "\n", 
             "\t\t\t\t\t\t\t", 
             RowBox[{"{", 
              RowBox[{"v", ",", 
               RowBox[{"vpm", "[", 
                
                RowBox[{"\"\<minus\>\"", ",", "mdm", ",", "ER", ",", "labelT",
                  ",", "vavg"}], "]"}], ",", 
               RowBox[{"vesc", "-", "vavg"}]}], "}"}], " ", ",", 
             RowBox[{"AccuracyGoal", "\[Rule]", "20"}]}], "]"}]}], ")"}]}], ",",
         "\n", "\t\t\t\t\t", 
        RowBox[{"{", 
         RowBox[{"labelT", ",", 
          RowBox[{"isotopes", "[", "tar", "]"}]}], "}"}]}], "]"}], ")"}]}]}], 
   "\n", "\t", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"RTintegratedhalo", "[", 
      RowBox[{"labelOp_", ",", "tar_"}], "]"}], "[", 
     RowBox[{"mdm_", ",", "rsq_", ",", "Qdm_", ",", "\[Kappa]_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"RTintegratedgen", "[", 
      RowBox[{"labelOp", ",", "tar"}], "]"}], "[", 
     RowBox[{
     "mdm", ",", "rsq", ",", "Qdm", ",", "\[Kappa]", ",", "vEavg", ",", 
      "v0"}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"RTintegrateddisk", "[", 
      RowBox[{"labelOp_", ",", "tar_"}], "]"}], "[", 
