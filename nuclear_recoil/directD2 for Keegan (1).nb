  3.911409290375318*^9}},ExpressionUUID->"71f942c5-830a-4c72-b0a5-\
87fb074ce0b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"standard", " ", "halo", " ", "model"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "vesc", " ", "is", " ", "hard", " ", "coded", " ", "into", " ", "this"}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"vesc", "=", 
     FractionBox[
      RowBox[{
       RowBox[{"(*", "800", "*)"}], 
       RowBox[{"(*", "580", "*)"}], 
       RowBox[{"544", " ", 
        SuperscriptBox["10", "3"]}]}], "cval"]}], ";"}], 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "hard", " ", "coded", " ", "into", " ", "following", " ", "equations"}], 
     ",", " ", 
     RowBox[{"other", " ", "quantities", " ", "are", " ", "replaceable"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vs", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"232", " ", 
        SuperscriptBox["10", "3"]}], "cval"], "//", "N"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vplus", "=", 
     FractionBox[
      RowBox[{"30", " ", 
       SuperscriptBox["10", "3"]}], "cval"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vc", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"220", " ", 
        SuperscriptBox["10", "3"]}], "cval"], "//", "N"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v0", "=", "vc"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vEavg", "=", " ", 
     RowBox[{
      RowBox[{"avgvexp", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vss", "\[Rule]", "vs"}], ",", 
         RowBox[{"vpp", "\[Rule]", "vplus"}]}], "}"}]}], "//", "N"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"is", " ", "same", " ", "as", " ", "vs"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Nesc", "[", "v0_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"Erf", "[", 
       FractionBox["vesc", "v0"], "]"}], "-", 
      RowBox[{
       FractionBox["2", 
        RowBox[{"3", 
         SqrtBox["\[Pi]"]}]], 
       FractionBox["vesc", "v0"], 
       RowBox[{"(", "3", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"+", "2"}], "\[Beta]", " ", 
          FractionBox[
           SuperscriptBox["vesc", "2"], 
           SuperscriptBox["v0", "2"]]}], "*)"}], ")"}], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", " ", 
         FractionBox[
          SuperscriptBox["vesc", "2"], 
          SuperscriptBox["v0", "2"]]}]]}]}], 
     RowBox[{"(*", 
      RowBox[{"/.", 
       RowBox[{"{", 
        RowBox[{"\[Beta]", "\[Rule]", "0"}], "}"}]}], "*)"}], "//", "N"}]}], "\n", 
   RowBox[{
    RowBox[{"costhetamax", "[", 
     RowBox[{"v_", ",", "vE_"}], "]"}], " ", ":=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["vesc", "2"], "-", 
      SuperscriptBox["v", "2"], "-", 
      SuperscriptBox["vE", "2"]}], 
     RowBox[{"2", " ", "v", " ", "vE"}]]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vpm", " ", "[", 
     RowBox[{"\"\<plus\>\"", ",", "mdm_", ",", "ER_", ",", "labelT_", ",", 
      "vavg_"}], "]"}], ":=", " ", 
    RowBox[{"Min", "[", 
     RowBox[{
      RowBox[{"vmin", "[", 
       RowBox[{"ER", ",", 
        RowBox[{"mT", "[", "labelT", "]"}], ",", "mdm"}], "]"}], ",", 
      RowBox[{"vesc", "+", "vavg"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vpm", " ", "[", 
     RowBox[{"\"\<minus\>\"", ",", "mdm_", ",", "ER_", ",", "labelT_", ",", 
      "vavg_"}], "]"}], ":=", " ", 
    RowBox[{"Min", "[", 
     RowBox[{
      RowBox[{"vmin", "[", 
       RowBox[{"ER", ",", 
        RowBox[{"mT", "[", "labelT", "]"}], ",", "mdm"}], "]"}], ",", 
      RowBox[{"vesc", "-", "vavg"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fSHM", "[", 
      RowBox[{"v_", ",", "vavg_", ",", "cth_", ",", "vo_", ",", "Nes_"}], 
      "]"}], ":=", 
     FractionBox[
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["v", "2"], "+", 
           SuperscriptBox["vavg", "2"], "+", 
           RowBox[{"2", "v", " ", "vavg", " ", "cth"}]}], ")"}]}], "/", 
        SuperscriptBox["vo", "2"]}]], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"vo", 
          SqrtBox["\[Pi]"]}], ")"}], "3"], "Nes"}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"angularintminus", "[", 
      RowBox[{"v_", ",", "vavg_", ",", "vo_", ",", "Nes_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"2", "\[Pi]", " ", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"fSHM", "[", 
          RowBox[{"v", " ", ",", "vavg", ",", "cth", ",", "vo", ",", "Nes"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"cth", ",", 
           RowBox[{"-", "1"}], ",", 
           RowBox[{"costhetamax", " ", "[", 
            RowBox[{"v", ",", "vavg"}], "]"}]}], "}"}]}], "]"}]}], "//", 
      "Simplify"}]}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"angularintminus", "[", 
      RowBox[{"v_", ",", "vavg_", ",", "vo_", ",", "Nes_"}], "]"}], " ", "=", 
     FractionBox[
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", 
          FractionBox["289", 
           RowBox[{"87890625", " ", 
            SuperscriptBox["vo", "2"]}]]}]]}], "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"v", "-", "vavg"}], ")"}], "2"], 
          SuperscriptBox["vo", "2"]]}]]}], 
      RowBox[{"Nes", " ", 
       SqrtBox["\[Pi]"], " ", "v", " ", "vavg", " ", "vo"}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"angularintplus", "[", 
      RowBox[{"v_", ",", "vavg_", ",", "vo_", ",", "Nes_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"2", "\[Pi]", " ", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"fSHM", "[", 
          RowBox[{"v", " ", ",", "vavg", ",", "cth", ",", "vo", ",", "Nes"}], 
          "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"cth", ",", "1", ",", 
           RowBox[{"costhetamax", " ", "[", 
            RowBox[{"v", ",", "vavg"}], "]"}]}], "}"}]}], "]"}]}], "//", 
      "Simplify"}]}], " ", "\[IndentingNewLine]", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"angularintplus", "[", 
      RowBox[{"v_", ",", "vavg_", ",", "vo_", ",", "Nes_"}], "]"}], "=", 
     FractionBox[
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", 
          FractionBox["289", 
           RowBox[{"87890625", " ", 
            SuperscriptBox["vo", "2"]}]]}]]}], "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"v", "+", "vavg"}], ")"}], "2"], 
          SuperscriptBox["vo", "2"]]}]]}], 
      RowBox[{"Nes", " ", 
       SqrtBox["\[Pi]"], " ", "v", " ", "vavg", " ", "vo"}]]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FE1D", "[", 
     RowBox[{"v_", ",", "vavg_", ",", "vo_"}], "]"}], " ", ":=", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"HeavisideTheta", "[", 
        RowBox[{"vesc", "+", "vavg", "-", "v"}], "]"}], 
       SuperscriptBox["v", "2"], 
       RowBox[{"angularintminus", "[", 
        RowBox[{"v", ",", "vavg", ",", "vo", ",", 
         RowBox[{"Nesc", "[", "vo", "]"}]}], "]"}]}], " ", 
      "\[IndentingNewLine]", "-", " ", 
      RowBox[{
       RowBox[{"HeavisideTheta", "[", 
        RowBox[{"vesc", "-", "vavg", "-", "v"}], "]"}], 
       SuperscriptBox["v", "2"], 
       RowBox[{"angularintplus", "[", 
        RowBox[{"v", ",", "vavg", ",", "vo", ",", 
         RowBox[{"Nesc", "[", "vo", "]"}]}], "]"}]}]}], " ", ")"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
